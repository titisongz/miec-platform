# dependencies
node_modules/

# next.js build output
.next/
out/

# PWA — service worker généré par next-pwa au build
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map
public/fallback-*.js
public/worker-*.js

# env files (contain secrets)
.env.local
.env*.local
.env.e2e

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# typescript — fichiers régénérés à chaque compilation, jamais édités à la main
# tsconfig.tsbuildinfo : cache du mode incrémental de tsc.
# next-env.d.ts : généré par `next dev`/`next build` (le fichier le dit lui-même) ;
#   il référence .next/types/routes.d.ts, qui n'existe qu'après un build — le
#   versionner n'apporte donc rien et crée du bruit à chaque montée de version.
tsconfig.tsbuildinfo
next-env.d.ts

# vercel
.vercel

# OS
.DS_Store
