# ── Identifiants des comptes de test E2E ────────────────────────────────────
# Copiez ce fichier en tests/e2e/.env.e2e (NON versionné) et renseignez de VRAIS
# comptes existant dans votre projet Supabase, avec les rôles indiqués et un
# email déjà confirmé. Les tests pilotent l'interface réelle et la vraie base.
#
# NB : NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY sont lus depuis
# votre .env.local existant (racine du projet) — inutile de les redéclarer ici.

# Compte rôle « membre »
E2E_MEMBER_EMAIL=membre.e2e@example.com
E2E_MEMBER_PASSWORD=change-me

# Compte rôle « responsable » (accès /admin)
E2E_RESPONSABLE_EMAIL=responsable.e2e@example.com
E2E_RESPONSABLE_PASSWORD=change-me

# Compte rôle « super_admin » (accès /superadmin + mode maintenance)
E2E_SUPERADMIN_EMAIL=superadmin.e2e@example.com
E2E_SUPERADMIN_PASSWORD=change-me

# URL de base (optionnel — défaut http://localhost:3000)
# E2E_BASE_URL=http://localhost:3000
